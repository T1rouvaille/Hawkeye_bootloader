# Custom build rule: generate XModem-ready binary from srec
# This file is included by Debug/makefile and is NOT overwritten by e2 studio

ra2e1_app_crc.bin: ra2e1_app.srec
	@echo Generating XModem binary: ra2e1_app_crc.bin
	srecord163\srec_cat.exe ra2e1_app.srec -Crop 0x4000 0x1FFF8 -Fill 0xFF 0x4000 0x1FFF8 -crc16-l-e 0x1FFF8 -XMODEM -Fill 0xFF 0x1FFFC 0x20000 -offset -0x4000 -o ra2e1_app_crc.bin -binary
	@echo Done: ra2e1_app_crc.bin

# Hook into post-build to auto-generate the .bin
post-build: ra2e1_app_crc.bin
