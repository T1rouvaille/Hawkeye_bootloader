<style>
table { border-collapse: collapse; }
td, th { border: 1px solid #000000; padding: 5px 8px; font-size: 11pt; }
th { background-color: #4472C4; color: #FFFFFF; font-weight: bold; text-align: center; }
tr:nth-child(even) { background-color: #D9E2F3; }
.section { background-color: #8FAADC; color: #FFFFFF; font-weight: bold; font-size: 12pt; text-align: center; }
td.code { font-family: Consolas, monospace; background-color: #FFF2CC; }
td.resp { font-family: Consolas, monospace; background-color: #E2EFDA; }
td.warn { color: #C00000; font-weight: bold; }
</style>
